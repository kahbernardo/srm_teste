{
  "name": "srm-credit-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de Cessão de Crédito Multimoedas - SRM Asset",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:web": "npm run dev -w apps/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "npm run test:integration -w apps/backend",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:setup": "npm run db:setup -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "db:studio": "npm run prisma:studio -w apps/backend"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "husky": "^8.0.3",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.2.4"
}
